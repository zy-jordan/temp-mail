[Unit]
Description=Temp Mail API
After=network.target

[Service]
User=root
WorkingDirectory=/opt/temp-mail
EnvironmentFile=-/opt/temp-mail/.env
ExecStart=/bin/bash -lc '/opt/temp-mail/venv/bin/uvicorn app.api:app --host "${TEMP_MAIL_HOST:-0.0.0.0}" --port "${TEMP_MAIL_PORT:-8000}"'
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
